datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Claimant {
  id              String           @id @default(uuid())
  trackingId      String           @unique
  firstName       String
  lastName        String
  email           String
  phone           String?
  claimType       String?
  status          String           @default("Submitted")
  state           String?
  filedDate       String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  claims          Claim[]
  contactMessages ContactMessage[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Claim {
  id          String   @id @default(uuid())
  trackingId  String   @unique
  status      String   @default("Pending")
  claimType   String?
  description String?
  claimantId  String
  filedDate   DateTime @default(now())
  lastUpdated DateTime @updatedAt
  notes       String?
  nextSteps   String?
  claimant    Claimant @relation(fields: [claimantId], references: [id])
  history     ClaimHistory[]
}

model ClaimHistory {
  id        String   @id @default(uuid())
  status    String
  notes     String?
  date      DateTime @default(now())
  claimId   String
  claim     Claim    @relation(fields: [claimId], references: [id])
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  phone      String?
  claimId    String?
  message    String
  fileName   String?
  fileSize   String?
  claimantId String?
  claimant   Claimant? @relation(fields: [claimantId], references: [id])
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  claimType String?
  updates   Boolean  @default(true)
  deadlines Boolean  @default(true)
  tips      Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Referral {
  id            String   @id @default(uuid())
  referrerName  String
  referrerEmail String
  referrerPhone String?
  referralFirst String
  referralLast  String
  referralPhone String
  claimType     String?
  status        String   @default("Pending")
  payoutAmount  String   @default("5000")
  paidOut       Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MediaItem {
  id        String   @id @default(uuid())
  key       String   @unique
  category  String
  filePath  String
  fileName  String
  alt       String   @default("")
  title     String   @default("")
  mediaType String   @default("image")
  sortOrder Int      @default(0)
  fileSize  Int      @default(0)
  mimeType  String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([key])
}
