datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Claimant {
  id         String   @id @default(uuid())
  trackingId String   @unique
  firstName  String
  lastName   String
  email      String
  phone      String?
  claimType  String?
  status     String   @default("Submitted")
  state      String?
  filedDate  String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
